{
  "version": 2,
  "public": true,
  "github": {
    "silent": true
  },
  "routes": [
    {
      "src": "/overview",
      "dest": "/overview/index.html"
    },
    {
      "src": "/overview/(.*)",
      "dest": "/overview/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/apps/mobile/index.html"
    }
  ]
}
