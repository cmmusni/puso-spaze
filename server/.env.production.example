# ═══════════════════════════════════════════════════════════
# PUSO Spaze Backend — Production Environment
# DO NOT commit this with real values; use Railway secrets instead
# ═══════════════════════════════════════════════════════════

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/puso_spaze

# Node environment
NODE_ENV=production
PORT=3000

# OpenAI API Key (for content moderation)
OPENAI_API_KEY=sk-proj-...

# Gmail credentials (for sending invite codes)
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASS=your-app-specific-password

# CORS (Allow frontend domain)
CORS_ORIGIN=https://puso-spaze.org