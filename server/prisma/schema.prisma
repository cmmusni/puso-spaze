// ─────────────────────────────────────────────
// prisma/schema.prisma
// PUSO Spaze data models: User, Post
// Run: npx prisma migrate dev
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── UserRole enum ─────────────────────────────
enum UserRole {
  USER
  COACH
  ADMIN
}

// ── User ─────────────────────────────────────
model User {
  id            String   @id @default(uuid())
  displayName   String   @unique
  role          UserRole @default(USER)
  expoPushToken String?  // For mobile push notifications
  createdAt     DateTime @default(now())

  posts         Post[]
  reactions     Reaction[]
  comments      Comment[]
  notifications Notification[]

  @@map("users")
}

// ── InviteCode ────────────────────────────────
model InviteCode {
  id        String    @id @default(uuid())
  code      String    @unique
  used      Boolean   @default(false)
  usedBy    String?
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@map("invite_codes")
}

// ── ModerationStatus enum ─────────────────────
enum ModerationStatus {
  SAFE
  FLAGGED
  REVIEW
}

// ── Post ─────────────────────────────────────
model Post {
  id               String           @id @default(uuid())
  content          String
  userId           String
  createdAt        DateTime         @default(now())
  moderationStatus ModerationStatus @default(REVIEW)
  tags             String[]
  pinned           Boolean          @default(false)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]
  comments  Comment[]

  @@map("posts")
}

// ── ReactionType enum ─────────────────────────
enum ReactionType {
  PRAY
  CARE
  SUPPORT
}

// ── Reaction ──────────────────────────────────
model Reaction {
  id        String       @id @default(uuid())
  postId    String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One reaction per user per post (toggle by replace)
  @@unique([postId, userId])
  @@map("reactions")
}

// ── Comment ───────────────────────────────────
model Comment {
  id               String           @id @default(uuid())
  postId           String
  userId           String
  content          String
  createdAt        DateTime         @default(now())
  moderationStatus ModerationStatus @default(REVIEW)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ── NotificationType enum ─────────────────────
enum NotificationType {
  REACTION      // Someone reacted to your post
  COMMENT       // Someone commented on your post
  ENCOURAGEMENT // New encouragement post
  SYSTEM        // System announcements
}

// ── Notification ──────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  userId    String           // Recipient
  type      NotificationType
  title     String
  body      String
  data      Json?            // Additional metadata (postId, actorId, etc.)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

// ── AppConfig ───────────────────────────────
model AppConfig {
  id                Int      @id @default(1)
  hourlyHopePostingEnabled Boolean  @default(true)
  hourlyHopeVisible Boolean  @default(true)
  hourlyHopeEnabled Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("app_config")
}
