// ─────────────────────────────────────────────
// prisma/schema.prisma
// PUSO Spaze data models: User, Post
// Run: npx prisma migrate dev
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── UserRole enum ─────────────────────────────
enum UserRole {
  USER
  COACH
  ADMIN
}

// ── User ─────────────────────────────────────
model User {
  id            String   @id @default(uuid())
  displayName   String   @unique
  deviceId      String?  // Permanent device UUID — only this device can use this username
  pin           String?  @unique // Random PIN code for cross-device login
  role          UserRole @default(USER)
  isAnonymous          Boolean  @default(false) // Hide identity from community
  expoPushToken        String?  // For mobile push notifications
  webPushSubscription  Json?    // Web Push API subscription object (endpoint, keys)
  email                String?  // Coach email address (from invite code)
  avatarUrl            String?  // Profile picture URL
  notificationsEnabled Boolean  @default(true)  // Daily reflection reminder push notifications
  createdAt            DateTime @default(now())
  lastActiveAt         DateTime @default(now())

  posts         Post[]
  reactions     Reaction[]
  comments      Comment[]
  commentReactions CommentReaction[]
  notifications Notification[]
  journals      Journal[]
  conversationsAsUser  Conversation[] @relation("ConversationUser")
  conversationsAsCoach Conversation[] @relation("ConversationCoach")
  messages      Message[]

  @@map("users")
}

// ── InviteCode ────────────────────────────────
model InviteCode {
  id        String    @id @default(uuid())
  code      String    @unique
  email     String?   // Email of the invited coach
  used      Boolean   @default(false)
  usedBy    String?
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@map("invite_codes")
}

// ── ModerationStatus enum ─────────────────────
enum ModerationStatus {
  SAFE
  FLAGGED
  REVIEW
}

// ── Post ─────────────────────────────────────
model Post {
  id               String           @id @default(uuid())
  content          String
  imageUrl         String?
  userId           String
  createdAt        DateTime         @default(now())
  moderationStatus ModerationStatus @default(REVIEW)
  tags             String[]
  pinned           Boolean          @default(false)
  isAnonymous      Boolean          @default(false) // Was posted in anonymous mode
  anonDisplayName  String?          // Frozen anon name at time of posting

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]
  comments  Comment[]

  @@map("posts")
}

// ── ReactionType enum ─────────────────────────
enum ReactionType {
  PRAY
  CARE
  SUPPORT
  LIKE
}

// ── Reaction ──────────────────────────────────
model Reaction {
  id        String       @id @default(uuid())
  postId    String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One reaction per user per post (toggle by replace)
  @@unique([postId, userId])
  @@map("reactions")
}

// ── Comment ───────────────────────────────────
model Comment {
  id               String           @id @default(uuid())
  postId           String
  userId           String
  content          String
  createdAt        DateTime         @default(now())
  moderationStatus ModerationStatus @default(REVIEW)
  isAnonymous      Boolean          @default(false)
  anonDisplayName  String?
  parentId         String?

  post     Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[]         @relation("CommentReplies")
  reactions CommentReaction[]

  @@map("comments")
}

// ── CommentReaction ───────────────────────────
model CommentReaction {
  id        String       @id @default(uuid())
  commentId String
  userId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_reactions")
}

// ── NotificationType enum ─────────────────────
enum NotificationType {
  REACTION      // Someone reacted to your post
  COMMENT       // Someone commented on your post
  ENCOURAGEMENT // New encouragement post
  SYSTEM        // System announcements
  MESSAGE       // New chat message from a user
}

// ── Notification ──────────────────────────────
model Notification {
  id        String           @id @default(uuid())
  userId    String           // Recipient
  type      NotificationType
  title     String
  body      String
  data      Json?            // Additional metadata (postId, actorId, etc.)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

// ── Journal ───────────────────────────────────
model Journal {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  mood      String?  // e.g. "grateful", "anxious", "hopeful", "peaceful", "sad"
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("journals")
}

// ── Conversation ──────────────────────────────
// A conversation between a user and a coach.
// All coaches/admins can see all conversations (no private DMs).
model Conversation {
  id        String   @id @default(uuid())
  userId    String   // The member who started the conversation
  coachId   String   // The coach the conversation is with
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation("ConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  coach    User      @relation("ConversationCoach", fields: [coachId], references: [id], onDelete: Cascade)
  messages Message[]

  // One conversation per user-coach pair
  @@unique([userId, coachId])
  @@index([userId])
  @@index([coachId])
  @@map("conversations")
}

// ── Message ───────────────────────────────────
model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ── AppConfig ───────────────────────────────
model AppConfig {
  id                Int      @id @default(1)
  hourlyHopePostingEnabled Boolean  @default(true)
  hourlyHopeVisible Boolean  @default(true)
  hourlyHopeEnabled Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("app_config")
}

// ── RecoveryRequest ───────────────────────────
// A locked-out user requests account recovery. Coaches review and approve.
model RecoveryRequest {
  id           String   @id @default(uuid())
  displayName  String   // The username the user claims
  reason       String   // User's explanation ("cleared cache", "new phone", etc.)
  status       String   @default("PENDING") // PENDING | APPROVED | DENIED
  reviewedBy   String?  // Coach userId who reviewed
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([status, createdAt])
  @@map("recovery_requests")
}
